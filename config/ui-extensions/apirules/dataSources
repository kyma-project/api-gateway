relatedGateways:
  resource:
    kind: Gateway
    group: networking.istio.io
    version: v1beta1
    namespace: null
relatedServices:
  resource:
    kind: Service
    version: v1
    namespace: null
virtualServices:
  resource:
    kind: VirtualService
    group: networking.istio.io
    version: v1beta1
    namespace: null
  filter: '$item.metadata.labels."apirule.gateway.kyma-project.io/name" = $root.metadata.name and $item.metadata.labels."apirule.gateway.kyma-project.io/namespace" = $root.metadata.namespace'
relatedRequestAuthentications:
  resource:
    kind: RequestAuthentication
    group: security.istio.io
    version: v1
    namespace: null
  filter: '$item.metadata.labels."apirule.gateway.kyma-project.io/name" = $root.metadata.name and $item.metadata.labels."apirule.gateway.kyma-project.io/namespace" = $root.metadata.namespace'
relatedAuthorizationPolicies:
  resource:
    kind: AuthorizationPolicy
    group: security.istio.io
    version: v1
    namespace: null
  filter: '$item.metadata.labels."apirule.gateway.kyma-project.io/name" = $root.metadata.name and $item.metadata.labels."apirule.gateway.kyma-project.io/namespace" = $root.metadata.namespace'
relatedExternalGateway:
  resource:
    kind: ExternalGateway
    group: gateway.kyma-project.io
    version: v1alpha1
    namespace: null
  filter: '$exists($root.spec.externalGateway) and $item.metadata.name = $split($root.spec.externalGateway, "/")[1] and $item.metadata.namespace = $split($root.spec.externalGateway, "/")[0]'